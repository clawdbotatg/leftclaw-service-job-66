# Template for NextJS environment variables.
#
# For local development, copy this file to .env.local and fill in the values.
# For the Vercel deploy, set these in the Vercel project dashboard
# (Project Settings → Environment Variables). Never commit real values.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Everything else is server-only and is read inside /app/api/* route handlers.

# --- Public (browser-safe) ---

# Alchemy API key used by the frontend (wagmi/viem) and the server RPC client.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect Cloud project ID (from https://cloud.walletconnect.com).
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Absolute base URL of the production site. Used for OG images / metadata.
# Example: https://leftclaw-service-job-66-nextjs.vercel.app
NEXT_PUBLIC_PRODUCTION_URL=

# --- Server-only (never exposed to the browser) ---

# Private key of the relayer wallet (same wallet that is the ClawdPFP minter
# at 0xB5741B033c45330A34952436a34b1B25a208Af10). Pays gas for gasless mints.
RELAYER_PRIVATE_KEY=

# Shared secret used to authenticate /api/cv/spend calls against larv.ai.
CV_SPEND_SECRET=

# BGIPFS upload token (https://upload.bgipfs.com). Used for pinning the
# generated PNG and the token metadata JSON during mint.
BGIPFS_TOKEN=
